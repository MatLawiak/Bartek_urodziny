    "Wyślij email do Bartka":        { "main": [[{ "node": "Odpowiedź POST",                "type": "main", "index": 0 }]] },
    "Webhook GET — Licznik":         { "main": [[{ "node": "Zwróć licznik",                 "type": "main", "index": 0 }]] },
    "Zwróć licznik":                 { "main": [[{ "node": "Odpowiedź GET",                 "type": "main", "index": 0 }]] },
    "Webhook GET — Lista (admin)":   { "main": [[{ "node": "Sprawdź klucz i zwróć listę",  "type": "main", "index": 0 }]] },
    "Sprawdź klucz i zwróć listę":  { "main": [[{ "node": "Odpowiedź lista",               "type": "main", "index": 0 }]] }
